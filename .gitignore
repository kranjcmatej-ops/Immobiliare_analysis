# Ignore everything by default, then whitelist what should be on GitHub
/*

# Git internals
!.git
!.gitignore

# GitHub Actions workflows
!.github/
.github/*
!.github/workflows/
!.github/workflows/*.yml

# Python scripts and dependencies
!fetch_listings.py
!fetch_peschiera_listings.py
!requirements.txt

# Snapshot history (JSON data files) — Rodano
!listings_history/
listings_history/*
!listings_history/*.json

# Snapshot history (JSON data files) — Peschiera
!peschiera_listings_history/
peschiera_listings_history/*
!peschiera_listings_history/*.json

# HTML outputs
!map_listings.html
!peschiera_map.html
!Rodano_Terracielo_Valuation_Report_v3.html

# Docs
!README.md
